# =====================================================================
# DevRose API — full .env.example
# =====================================================================
# This file documents every environment variable the platform reads,
# grouped by feature area. The production deploy pipeline should
# provision these via the cloud provider's secret store; for local
# dev, copy this file to ``.env`` (gitignored) and fill in the
# values you have. EVERY variable below is optional EXCEPT where
# marked [REQUIRED]; the app boots on SQLite without anything set
# and falls back to in-memory channels + in-memory cache.
# =====================================================================

# ---------------------------------------------------------------------
# Part 8 — environment detection
# ---------------------------------------------------------------------
# [REQUIRED for prod/staging]  one of: development | staging | production
# Used by the preflight command + the /api/version/ endpoint.
DJANGO_ENV=development

# App version label. Set by the deploy pipeline; consumed by
# /api/version/ and the VersionBadge FE component.
APP_VERSION=1.0.0
# Git SHA for the version endpoint (auto-set by CI).
GIT_SHA=
COMMIT_SHA=

# ---------------------------------------------------------------------
# Part 8 — maintenance mode (optional runtime override)
# ---------------------------------------------------------------------
# Set to 1 in the deploy pipeline when draining traffic to a new
# pod. The API can toggle this at runtime via
# POST /api/maintenance/ instead.
MAINTENANCE_MODE_ENABLED=0

# ---------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------
# [REQUIRED for prod] 50+ char random string. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=django-insecure-DEV-ONLY-DO-NOT-USE-IN-PRODUCTION

# Django debug toggle. 1 in dev, 0 in prod.
DJANGO_DEBUG=1

# Comma-separated allow-list of hostnames (no scheme, no port).
# Example: devrose.onrender.com,api-devrose.onrender.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated CORS allow-list of full origins (scheme+host+port).
# Example: https://devrose.onrender.com,http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional: extra regexes matched against the request Origin header.
# Defaults ALREADY cover GitHub Codespaces (`*.app.github.dev` on
# port 3000/5173) and Gitpod. Set this only if you need additional
# preview subdomains.
# Example: ^https://.*\.my-staging\.com$
CORS_ALLOWED_ORIGIN_REGEXES=

# Optional: redirect all non-HTTPS traffic to HTTPS (prod only).
# Set to 0 behind a TLS-terminating LB if it sets X-Forwarded-Proto.
DJANGO_SECURE_SSL_REDIRECT=1

# ---------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------
# When unset the app uses SQLite (BASE_DIR/db.sqlite3).
# For Supabase set both DATABASE_URL (pooler, port 6543) AND DIRECT_URL
# (direct, port 5432) so the migration command can route DDL through
# the direct connection.
DATABASE_URL=
DIRECT_URL=

# Pool mode: transaction | session. Default is auto-detected from the
# port (6543=transaction, 5432=session). Set explicitly when running
# on a non-standard port.
DATABASE_POOL_MODE=

# ---------------------------------------------------------------------
# Supabase (auth + storage)
# ---------------------------------------------------------------------
# Empty in dev → Django-only auth fallback. Required for prod.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Legacy aliases (still accepted): SUPABASE_ANON_KEY, SUPABASE_SERVICE_KEY.
# New names (post-2025): SUPABASE_SECRET_KEY.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_KEY=
# Optional: JWKS URL for Supabase RS256 token verification.
SUPABASE_JWKS_URL=

# ---------------------------------------------------------------------
# Redis (channels-redis + presence ledger + cache)
# ---------------------------------------------------------------------
# Set in any non-trivial deploy so the chat fabric scales beyond a
# single Daphne worker. Format: redis://[:password@]host:port/db
REDIS_URL=

# ---------------------------------------------------------------------
# AI integrations
# ---------------------------------------------------------------------
GEMINI_API_KEY=
# Optional: model name (default: gemini-1.5-flash-latest)
GEMINI_MODEL=gemini-1.5-flash-latest

# ---------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------
# Set to 0 to disable AI smart features (Part 5) at the API level.
ENABLE_AI_FEATURES=1
# Set to 0 to disable scheduled messages (Part 5).
ENABLE_SCHEDULED_MESSAGES=1
# Set to 0 to disable the premium tier (Part 5).
ENABLE_PREMIUM_TIER=1

# ---------------------------------------------------------------------
# File uploads
# ---------------------------------------------------------------------
# 10 MB by default. The base64 photo path in views/chat.py can hit
# this ceiling for large images.
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

# ---------------------------------------------------------------------
# Observability (Part 8 — out of scope for this slice)
# ---------------------------------------------------------------------
# Sentry DSN — drop the integration in once Sentry is provisioned.
SENTRY_DSN=
# Log level for production (default WARNING, dev = INFO).
LOG_LEVEL=INFO

# ---------------------------------------------------------------------
# CI / deploy (Part 8 — preflight command reads these)
# ---------------------------------------------------------------------
# Optional commit SHA + actor for the DeploymentEvent audit trail.
CI_ACTOR=
# Port Daphne binds in the deploy image (used by preflight's healthz check).
DJANGO_PORT=8000
# Render-specific host hint (auto-detected by settings.py).
RENDER_EXTERNAL_HOSTNAME=
