# DevRose Academy — environment variable template
# -----------------------------------------------
# Copy this file to `.env` (frontend) and to `backend/.env` (backend),
# then fill in your real values. Both files are gitignored.
#
# Restart vite (`run_vite.sh`) and daphne (`run_daphne.sh`) after editing.

# ─────── Frontend (Vite) ───────
# (no secrets here on purpose — see Backend section below for the Gemini key)

# Optional: absolute backend URL for devices or deployments that cannot use
# the local Vite proxy. Leave unset for same-origin `/api/` requests.
VITE_API_BASE_URL=https://api-devrose.onrender.com/api/

# Optional: override the WebSocket host used by the Kot3Chat client.
# Leave unset to use the same host as the page (works with vite proxy).
# VITE_KOT3_WS_HOST=localhost:3000

# Optional: Supabase Auth (frontend). Leave unset to keep Django-only auth.
# When BOTH are set, the Auth modal exposes a "Use Supabase" path that
# calls supabase.auth.signInWithPassword / signUp. The resulting JWT is
# mirrored into localStorage AND validated by the Django JWKS verifier
# in `backend/api/auth/custom.py::_authenticate_supabase_jwt`, so /api/me/
# + /api/login/ + /api/signup/ all accept Supabase users transparently.
# Find these under Supabase dashboard → Project Settings → API.
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────── Backend (Django) ───────
# Copy these into backend/.env (Django reads them via os.environ).
SECRET_KEY=django-insecure-replace-me-with-a-strong-random-value
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Required for AI Copilot (LiveClassroom) + Chatbot. Get a key at
# https://aistudio.google.com/apikey (Google AI Studio). The Django view
# backend/api/views/ai.py reads this from os.environ — never expose it client-side.
GEMINI_API_KEY=your-gemini-secure-backend-key-here

# Optional database URL (uncomment to switch off SQLite for dev).
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/devrose

# Optional: Redis-backed Channels layer for prod (uncomment in INSTALLED_APPS / settings.py too).
# REDIS_URL=redis://127.0.0.1:6379/0
